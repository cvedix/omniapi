{
    "solutionId": "ba_crossline_mqtt_default",
    "solutionName": "Behavior Analysis - Crossline with MQTT",
    "solutionType": "behavior_analysis",
    "isDefault": false,
    "description": "Phát hiện đối tượng vượt qua đường line với MQTT event publishing",
    "category": "behavior_analysis",
    "pipeline": [
        {
            "nodeType": "file_src",
            "nodeName": "file_src_{instanceId}",
            "parameters": {
                "file_path": "${FILE_PATH}",
                "channel": "0",
                "resize_ratio": "${RESIZE_RATIO}"
            }
        },
        {
            "nodeType": "yolo_detector",
            "nodeName": "yolo_detector_{instanceId}",
            "parameters": {
                "model_path": "${MODEL_PATH}",
                "labels_path": "${LABELS_PATH}",
                "backend_type": "${BACKEND_TYPE}",
                "score_threshold": "${detectionSensitivity}",
                "nms_threshold": "0.4"
            }
        },
        {
            "nodeType": "sort_track",
            "nodeName": "sort_tracker_{instanceId}",
            "parameters": {}
        },
        {
            "nodeType": "ba_crossline",
            "nodeName": "ba_crossline_{instanceId}",
            "parameters": {
                "line_channel": "0",
                "line_start_x": "${CROSSLINE_START_X}",
                "line_start_y": "${CROSSLINE_START_Y}",
                "line_end_x": "${CROSSLINE_END_X}",
                "line_end_y": "${CROSSLINE_END_Y}"
            }
        },
        {
            "nodeType": "json_crossline_mqtt_broker",
            "nodeName": "json_crossline_mqtt_broker_{instanceId}",
            "parameters": {}
        },
        {
            "nodeType": "ba_crossline_osd",
            "nodeName": "osd_{instanceId}",
            "parameters": {}
        },
        {
            "nodeType": "file_des",
            "nodeName": "file_des_{instanceId}",
            "parameters": {
                "save_dir": "./output/{instanceId}",
                "name_prefix": "ba_crossline_mqtt",
                "osd": "true"
            }
        }
    ],
    "defaults": {
        "detectorMode": "SmartDetection",
        "detectionSensitivity": "0.7",
        "sensorModality": "RGB",
        "RESIZE_RATIO": "1.0",
        "BACKEND_TYPE": "tensorrt"
    },
    "requiredParams": {
        "FILE_PATH": "Đường dẫn file video input (hoặc dùng RTSP_SRC_URL)",
        "LABELS_PATH": "Đường dẫn labels file",
        "CROSSLINE_START_X": "Tọa độ X điểm đầu đường line",
        "CROSSLINE_START_Y": "Tọa độ Y điểm đầu đường line",
        "CROSSLINE_END_X": "Tọa độ X điểm cuối đường line",
        "CROSSLINE_END_Y": "Tọa độ Y điểm cuối đường line",
        "MODEL_PATH": "Đường dẫn model detector (.engine/.onnx/.xml)"
    },
    "optionalParams": {
        "RTSP_SRC_URL": "URL RTSP stream (thay thế FILE_PATH)",
        "RTMP_URL": "URL RTMP server (thay thế file_des)",
        "RESIZE_RATIO": "Tỷ lệ resize video (0.0-1.0), mặc định 1.0",
        "BACKEND_TYPE": "Backend detector: tensorrt | onnx | openvino (mặc định tensorrt)"
    }
}
