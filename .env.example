# Edge AI API Environment Variables
# ============================================
# This file contains ONLY environment variables that are REQUIRED before
# the application starts (systemd service, GStreamer initialization, etc.)
#
# For application settings (API port, logging, performance, etc.), use config.json
# Priority: config.json > Environment Variables > Defaults
#
# Copy this file to .env and customize for your environment:
#   cp .env.example .env
#
# DEV: Chạy với --dev để load file này (hoặc .env) từ project root và ghi đè env:
#      ./build/bin/edgeos-api --dev
#      Không cần source .env hay chạy scripts/load_env.sh.

# ============================================
# Configuration File Path (Optional)
# ============================================
# Override config.json path if needed
# Auto-detection order: CONFIG_FILE > ./config.json > /opt/edgeos-api/config/config.json > /etc/edgeos-api/config.json
# If not set, system will auto-detect config.json in the following order:
#   1. ./config.json (current directory - development)
#   2. /opt/edgeos-api/config/config.json (production)
#   3. /etc/edgeos-api/config.json (system-wide)
#   4. ~/.config/edgeos-api/config.json (user config)
# CONFIG_FILE=/opt/edgeos-api/config/config.json

# ============================================
# Logging (Dev: thư mục log trong project)
# ============================================
# Thư mục gốc log: api/, general/, instance/<id>/, sdk_output/
# Dev: dùng ./logs (tương đối CWD khi chạy từ project root) hoặc đường dẫn tuyệt đối
# Production: /opt/edgeos-api/logs (hoặc cấu hình trong config.json system.logging)
LOG_DIR=./logs

# Bật ghi log ra file (API + instance). 1 = bật → logs/api/, logs/instance/<id>/
# Dev: bật sẵn để luôn có log instance khi chạy --dev. Production: tắt hoặc set 0
EDGEOS_LOG_FILES=1

# Mức log (TRACE, DEBUG, INFO, WARN, ERROR). Ưu tiên config.json system.logging.log_level
# LOG_LEVEL=DEBUG

# ============================================
# Worker Configuration (Subprocess Mode)
# ============================================
# Execution mode determines how AI workers run
# - "in-process": Workers run in main process (default, more stable, recommended)
# - "subprocess": Workers run in separate processes (isolated, requires worker binary)
#   Use subprocess mode for better isolation and crash recovery
EDGE_AI_EXECUTION_MODE=subprocess

# Worker executable path (only used in subprocess mode)
# Path to edgeos-worker binary that will be spawned for each instance
# Default: edgeos-worker (searches in PATH)
# Production: /usr/local/bin/edgeos-worker
# Development: ./build/bin/edgeos-worker or ./build/edgeos-worker
EDGE_AI_WORKER_PATH=edgeos-worker

# Socket directory for IPC (Inter-Process Communication) between main process and workers
# Used in subprocess mode for Unix domain sockets
# Production: /opt/edgeos-api/run
# Dev: ./run hoặc /tmp (tránh quyền ghi khi chạy trong repo)
# Fallback: /tmp (if permission denied to create default directory)
# Socket files format: {EDGE_AI_SOCKET_DIR}/edgeos_worker_{instance_id}.sock
EDGE_AI_SOCKET_DIR=/opt/edgeos-api/run

# ============================================
# GStreamer Configuration
# ============================================
# GStreamer plugin path - where GStreamer looks for plugins
# This is auto-detected by postinst script during package installation
# Only override if you have custom plugin location or plugins are installed elsewhere
# Common paths:
#   - x86_64: /usr/lib/x86_64-linux-gnu/gstreamer-1.0
#   - ARM64: /usr/lib/aarch64-linux-gnu/gstreamer-1.0
#   - ARM32: /usr/lib/arm-linux-gnueabihf/gstreamer-1.0
#   - All-in-one package: /opt/edgeos-api/lib/gstreamer-1.0
# GST_PLUGIN_PATH=/usr/lib/x86_64-linux-gnu/gstreamer-1.0

# GStreamer plugin feature rank - disable problematic plugins
# Set rank to NONE to prevent GStreamer from loading VA (Video Acceleration) plugins
# that may cause crashes on systems with broken GPU drivers
# Format: plugin_name:rank,plugin_name:rank
# Common problematic plugins: va, vaapi, vaapidecode, vaapipostproc
# GST_PLUGIN_FEATURE_RANK=va:NONE,vaapi:NONE,vaapidecode:NONE,vaapipostproc:NONE

# RTSP transport protocol for GStreamer
# - "tcp": More reliable, works through firewalls (default, recommended)
# - "udp": Faster but may be blocked by firewalls
# Use TCP for production, UDP only if in same network and firewall allows
GST_RTSP_PROTOCOLS=tcp

# Alternative RTSP transport setting (same as GST_RTSP_PROTOCOLS)
# Use "tcp" (default, more reliable) or "udp" (faster but may be blocked by firewall)
RTSP_TRANSPORT=tcp

# ============================================
# Storage Directories (Optional - Fallback)
# ============================================
# Có thể cấu hình trong config.json (ưu tiên). Env dùng khi không có trong config.
# Dev (chạy từ project root với --dev): dùng đường dẫn tương đối ./instances, ./models, ...
# Production: /opt/edgeos-api/instances, /opt/edgeos-api/models, ...
# Auto-detection: /opt/edgeos-api/{dir} → ~/.local/share/edgeos-api/{dir} → ./{dir}

# Instances directory - cấu hình và runtime của instances
# Dev: ./instances
# INSTANCES_DIR=./instances

# Models directory - file model AI
# MODELS_DIR=./models

# Solutions directory - cấu hình solution
# SOLUTIONS_DIR=./solutions

# Videos directory - file video upload
# VIDEOS_DIR=./videos

# Fonts directory - font OSD
# FONTS_DIR=./fonts

# Nodes directory - cấu hình node
# NODES_DIR=./nodes

# ============================================
# CVEDIX SDK Configuration (Optional)
# ============================================
# CVEDIX data/models root directory
# Path to CVEDIX SDK data directory containing models, fonts, etc.
# Default: ./cvedix_data/ (relative to current directory)
# Production: Usually set by CVEDIX SDK installation
# CVEDIX_DATA_ROOT=./cvedix_data/

# ============================================
# Development/Debug Options (Optional)
# ============================================
# X11 Display variable - for GUI applications
# Auto-detected from system, only override if needed
# Format: :0 (for first display), :1 (for second display), etc.
# DISPLAY=:0

# Wayland Display variable - for Wayland compositor
# Auto-detected from system, only override if needed
# WAYLAND_DISPLAY=wayland-0
