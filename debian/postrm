#!/bin/bash
# postrm script for omniapi

set -e

LIB_DIR="/opt/omniapi/lib"

# Remove ldconfig configuration
if [ -f "/etc/ld.so.conf.d/omniapi.conf" ]; then
    rm -f /etc/ld.so.conf.d/omniapi.conf
    ldconfig
fi

# Remove library directory if empty
if [ -d "$LIB_DIR" ]; then
    rmdir "$LIB_DIR" 2>/dev/null || true
fi

exit 0
