#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

# Use TMPDIR on /home/cvedix/Data (larger partition) to avoid disk space issues
# This ensures all build tools (strip, dh_strip, etc.) use the larger partition
export TMPDIR ?= /home/cvedix/Data/tmp
export TEMP = $(TMPDIR)
export TMP = $(TMPDIR)

# Build configuration
CMAKE_BUILD_TYPE ?= Release
CMAKE_FLAGS = -DCMAKE_BUILD_TYPE=$(CMAKE_BUILD_TYPE) \
              -DCMAKE_INSTALL_PREFIX=/usr \
              -DAUTO_DOWNLOAD_DEPENDENCIES=ON \
              -DDROGON_USE_FETCHCONTENT=ON

# Package configuration
PACKAGE_NAME = omniapi
INSTALL_DIR = /opt/omniapi
BIN_DIR = /usr/local/bin
LIB_DIR = /opt/omniapi/lib
SERVICE_USER = edgeai
SERVICE_GROUP = edgeai

# SDK configuration (EdgeOS SDK at /opt/edgeos-sdk)
SDK_EXTRACT_DIR = $(CURDIR)/debian/sdk_extract
CVEDIX_INSTALL_DIR = /opt/edgeos-sdk

%:
	dh $@

override_dh_auto_configure:
	# Create build directory
	mkdir -p $(CURDIR)/build
	cd $(CURDIR)/build && cmake .. $(CMAKE_FLAGS)

override_dh_auto_build:
	# Build project
	cd $(CURDIR)/build && make -j$$(nproc)

override_dh_auto_install:
	# Install executable - check multiple possible locations
	install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)
	@if [ -f $(CURDIR)/build/bin/omniapi ]; then \
		echo "Installing executable from build/bin/omniapi"; \
		install -m 755 $(CURDIR)/build/bin/omniapi $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/omniapi; \
	elif [ -f $(CURDIR)/build/omniapi ]; then \
		echo "Installing executable from build/omniapi"; \
		install -m 755 $(CURDIR)/build/omniapi $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/omniapi; \
	else \
		echo "Error: Executable not found in build directory"; \
		echo "Checked: $(CURDIR)/build/bin/omniapi"; \
		echo "Checked: $(CURDIR)/build/omniapi"; \
		ls -la $(CURDIR)/build/bin/ 2>/dev/null || echo "build/bin does not exist"; \
		ls -la $(CURDIR)/build/omniapi 2>/dev/null || echo "build/omniapi does not exist"; \
		exit 1; \
	fi

	# Install edgeos-worker executable (required for subprocess mode)
	@if [ -f $(CURDIR)/build/bin/edgeos-worker ]; then \
		echo "Installing worker executable from build/bin/edgeos-worker"; \
		install -m 755 $(CURDIR)/build/bin/edgeos-worker $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/edgeos-worker; \
	elif [ -f $(CURDIR)/build/edgeos-worker ]; then \
		echo "Installing worker executable from build/edgeos-worker"; \
		install -m 755 $(CURDIR)/build/edgeos-worker $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/edgeos-worker; \
	else \
		echo "Warning: edgeos-worker executable not found - subprocess mode will not work"; \
		echo "Checked: $(CURDIR)/build/bin/edgeos-worker"; \
		echo "Checked: $(CURDIR)/build/edgeos-worker"; \
	fi

	# Install bundled libraries - bundle directly from executable
	# Ensure lib directory exists
	install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR)
	# Find executable and bundle libraries
	@EXEC_PATH=""; \
	if [ -f $(CURDIR)/build/bin/omniapi ]; then \
		EXEC_PATH="$(CURDIR)/build/bin/omniapi"; \
	elif [ -f $(CURDIR)/build/omniapi ]; then \
		EXEC_PATH="$(CURDIR)/build/omniapi"; \
	fi; \
	if [ -n "$$EXEC_PATH" ] && [ -f "$$EXEC_PATH" ]; then \
		LIB_TEMP_DIR=$(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR); \
		$(CURDIR)/debian/bundle_libs.sh "$$EXEC_PATH" "$$LIB_TEMP_DIR" || true; \
		# Also ensure edgeos_core library is bundled if it exists \
		if [ -f $(CURDIR)/build/lib/libedgeos_core.so* ]; then \
			echo "Bundling edgeos_core library..."; \
			cp -L $(CURDIR)/build/lib/libedgeos_core.so* "$$LIB_TEMP_DIR/" 2>/dev/null || true; \
		fi; \
	fi; \
	# Also try to copy from pre-bundled location if exists (from build_deb.sh, before dh clean)
	if [ -d $(CURDIR)/debian/omniapi/opt/omniapi/lib ] && [ "$$(ls -A $(CURDIR)/debian/omniapi/opt/omniapi/lib 2>/dev/null)" ]; then \
		echo "Copying pre-bundled libraries..."; \
		cp -r $(CURDIR)/debian/omniapi/opt/omniapi/lib/* $(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR)/ 2>/dev/null || true; \
	fi

	# Copy libopencv_freetype.so.410 from build/lib (created by CMakeLists.txt or build script)
	# This is required for CVEDIX SDK compatibility
	# Must be done AFTER bundle_libs.sh to ensure it's not overwritten
	@LIB_TEMP_DIR=$(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR); \
	if [ ! -f "$$LIB_TEMP_DIR/libopencv_freetype.so.410" ]; then \
		FREETYPE_COPIED=false; \
		# Try build/lib first (created by CMakeLists.txt or build script) \
		if [ -f $(CURDIR)/build/lib/libopencv_freetype.so.410 ]; then \
			echo "Copying libopencv_freetype.so.410 from build/lib..."; \
			cp -L $(CURDIR)/build/lib/libopencv_freetype.so.410 "$$LIB_TEMP_DIR/" 2>/dev/null && FREETYPE_COPIED=true || true; \
			if [ "$$FREETYPE_COPIED" = true ]; then \
				echo "  ✓ libopencv_freetype.so.410 bundled from build/lib"; \
			fi; \
		fi; \
		# Try system OpenCV 4.6 if not found in build/lib \
		if [ "$$FREETYPE_COPIED" = false ]; then \
			FREETYPE_SOURCES="/usr/lib/x86_64-linux-gnu/libopencv_freetype.so.4.6.0 /usr/lib/x86_64-linux-gnu/libopencv_freetype.so.406 /usr/local/lib/libopencv_freetype.so.4.6.0 /usr/local/lib/libopencv_freetype.so.406 /usr/lib/libopencv_freetype.so.4.6.0 /usr/lib/libopencv_freetype.so.406"; \
			for source in $$FREETYPE_SOURCES; do \
				if [ -f "$$source" ]; then \
					echo "Copying libopencv_freetype.so.410 from $$source..."; \
					cp -L "$$source" "$$LIB_TEMP_DIR/libopencv_freetype.so.410" 2>/dev/null && FREETYPE_COPIED=true && break || true; \
				fi; \
			done; \
			if [ "$$FREETYPE_COPIED" = true ]; then \
				echo "  ✓ libopencv_freetype.so.410 bundled from system OpenCV 4.6"; \
			fi; \
		fi; \
		# Try SDK extract directory if available \
		if [ "$$FREETYPE_COPIED" = false ] && [ -d $(SDK_EXTRACT_DIR) ]; then \
			for sdk_source in $(SDK_EXTRACT_DIR)/opt/edgeos-sdk/lib/libopencv_freetype.so* $(SDK_EXTRACT_DIR)/usr/lib/x86_64-linux-gnu/libopencv_freetype.so*; do \
				if [ -f "$$sdk_source" ]; then \
					echo "Copying libopencv_freetype.so.410 from SDK extract..."; \
					cp -L "$$sdk_source" "$$LIB_TEMP_DIR/libopencv_freetype.so.410" 2>/dev/null && FREETYPE_COPIED=true && break || true; \
				fi; \
			done; \
			if [ "$$FREETYPE_COPIED" = true ]; then \
				echo "  ✓ libopencv_freetype.so.410 bundled from SDK extract"; \
			fi; \
		fi; \
		# Final check \
		if [ "$$FREETYPE_COPIED" = false ]; then \
			echo "  ✗ ERROR: libopencv_freetype.so.410 not found in any source"; \
			echo "  This file is REQUIRED for CVEDIX SDK compatibility"; \
			echo "  Please ensure OpenCV 4.6 is installed on build machine or file exists in build/lib"; \
			echo "  The package will be built but service may fail to start"; \
		fi; \
	fi; \
	# CRITICAL: Remove any conflicting freetype versions (e.g., .406) if .410 exists
	if [ -f "$$LIB_TEMP_DIR/libopencv_freetype.so.410" ]; then \
		for freetype_file in $$LIB_TEMP_DIR/libopencv_freetype.so.*; do \
			if [ -f "$$freetype_file" ] && [ "$$(basename $$freetype_file)" != "libopencv_freetype.so.410" ] && [ "$$(basename $$freetype_file)" != "libopencv_freetype.so.410.0" ]; then \
				echo "  Removing conflicting freetype version: $$(basename $$freetype_file)"; \
				rm -f "$$freetype_file" 2>/dev/null || true; \
			fi; \
		done; \
		echo "  ✓ Ensured only libopencv_freetype.so.410 is present"; \
	fi

	# Update RPATH in executables to use bundled libraries
	# RPATH: /opt/omniapi/lib:/opt/edgeos-sdk/lib/cvedix (relative to executable at /usr/local/bin)
	# CRITICAL: RPATH must be set correctly for bundled libraries to be found
	@EXPECTED_RPATH="/opt/omniapi/lib:/opt/edgeos-sdk/lib/cvedix"; \
	if command -v patchelf >/dev/null 2>&1; then \
		if [ -f $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/omniapi ]; then \
			echo "Setting RPATH for omniapi..."; \
			if patchelf --set-rpath "$$EXPECTED_RPATH" $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/omniapi 2>&1; then \
				VERIFIED_RPATH=$$(patchelf --print-rpath $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/omniapi 2>/dev/null || echo ""); \
				if [ "$$VERIFIED_RPATH" = "$$EXPECTED_RPATH" ]; then \
					echo "  ✓ RPATH set successfully for omniapi: $$VERIFIED_RPATH"; \
				else \
					echo "  ⚠  Warning: RPATH may not be set correctly. Expected: $$EXPECTED_RPATH, Got: $$VERIFIED_RPATH"; \
				fi; \
			else \
				echo "  ✗ ERROR: Failed to set RPATH for omniapi"; \
			fi; \
		fi; \
		if [ -f $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/edgeos-worker ]; then \
			echo "Setting RPATH for edgeos-worker..."; \
			if patchelf --set-rpath "$$EXPECTED_RPATH" $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/edgeos-worker 2>&1; then \
				VERIFIED_RPATH=$$(patchelf --print-rpath $(CURDIR)/debian/$(PACKAGE_NAME)$(BIN_DIR)/edgeos-worker 2>/dev/null || echo ""); \
				if [ "$$VERIFIED_RPATH" = "$$EXPECTED_RPATH" ]; then \
					echo "  ✓ RPATH set successfully for edgeos-worker: $$VERIFIED_RPATH"; \
				else \
					echo "  ⚠  Warning: RPATH may not be set correctly. Expected: $$EXPECTED_RPATH, Got: $$VERIFIED_RPATH"; \
				fi; \
			else \
				echo "  ✗ ERROR: Failed to set RPATH for edgeos-worker"; \
			fi; \
		fi; \
	else \
		echo "  ⚠  Warning: patchelf not found, RPATH cannot be set during build"; \
		echo "  RPATH must be set in postinst script or binary will not find bundled libraries"; \
	fi

	# Install systemd service
	install -d $(CURDIR)/debian/$(PACKAGE_NAME)/etc/systemd/system
	install -m 644 $(CURDIR)/deploy/omniapi.service $(CURDIR)/debian/$(PACKAGE_NAME)/etc/systemd/system/omniapi.service

	# Install config files (use config.json if present, else config/config.json.example)
	install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/config
	@if [ -f $(CURDIR)/config.json ]; then \
		install -m 644 $(CURDIR)/config.json $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/config/config.json; \
		echo "  Installed config.json"; \
	elif [ -f $(CURDIR)/config/config.json.example ]; then \
		install -m 644 $(CURDIR)/config/config.json.example $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/config/config.json; \
		echo "  Installed config/config.json.example as config.json"; \
	else \
		echo "  Warning: No config.json or config/config.json.example found"; \
		exit 1; \
	fi

	# Create directory structure from directories.conf
	# Read directories.conf directly (Makefile uses /bin/sh, not bash)
	@DIRS_CONF=$(CURDIR)/deploy/directories.conf; \
	if [ -f $$DIRS_CONF ]; then \
		echo "Reading directories from $$DIRS_CONF"; \
		DIR_LIST=$$(grep -E '^\s*\["' $$DIRS_CONF | sed 's/.*\["\([^"]*\)"\].*/\1/' | tr '\n' ' '); \
		for dir in $$DIR_LIST; do \
			install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/$$dir; \
		done; \
	else \
		echo "Warning: directories.conf not found, using fallback"; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/instances; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/solutions; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/groups; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/nodes; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/models; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/videos; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/fonts; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/logs; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/data; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/config; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/uploads; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/lib; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/run; \
	fi

	# Install README
	install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)
	install -m 644 $(CURDIR)/README.md $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/README.md

	# Install OpenAPI specification file
	install -m 644 $(CURDIR)/api-specs/openapi.yaml $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/openapi.yaml

	# Install api-specs/scalar directory (required for Scalar documentation)
	install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/api-specs/scalar
	if [ -d $(CURDIR)/api-specs/scalar ]; then \
		cp -r $(CURDIR)/api-specs/scalar/* $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/api-specs/scalar/; \
		find $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/api-specs/scalar -type f -exec chmod 644 {} \; || true; \
	fi

	# Install scripts directory (if needed)
	install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/scripts
	# Install validation and utility scripts
	if [ -f $(CURDIR)/packaging/scripts/validate_installation.sh ]; then \
		install -m 755 $(CURDIR)/packaging/scripts/validate_installation.sh $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/scripts/validate_installation.sh; \
	fi
	if [ -f $(CURDIR)/packaging/scripts/generate_version_manifest.sh ]; then \
		install -m 755 $(CURDIR)/packaging/scripts/generate_version_manifest.sh $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/scripts/generate_version_manifest.sh; \
	fi
	# Install OpenCV build script for user to install OpenCV 4.10 if needed
	if [ -f $(CURDIR)/scripts/build_opencv_safe.sh ]; then \
		install -m 755 $(CURDIR)/scripts/build_opencv_safe.sh $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/scripts/build_opencv_safe.sh; \
	fi

	# ============================================
	# Install EdgeOS SDK from extracted .deb to /opt/edgeos-sdk
	# ============================================
	@echo "Installing EdgeOS SDK from extracted package..."; \
	if [ -d $(SDK_EXTRACT_DIR) ] && [ -d $(SDK_EXTRACT_DIR)/opt/edgeos-sdk ]; then \
		SDK_SRC="$(SDK_EXTRACT_DIR)/opt/edgeos-sdk"; \
		install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(CVEDIX_INSTALL_DIR); \
		for item in $$SDK_SRC/*; do \
			BASENAME_ITEM=$$(basename "$$item"); \
			if [ -e "$$item" ] && [ "$$BASENAME_ITEM" != "README.md" ] && [ "$$BASENAME_ITEM" != "VERSION" ]; then \
				cp -r "$$item" $(CURDIR)/debian/$(PACKAGE_NAME)$(CVEDIX_INSTALL_DIR)/ 2>/dev/null || true; \
			fi; \
		done; \
		echo "  ✓ EdgeOS SDK integrated at $(CVEDIX_INSTALL_DIR)"; \
		if [ -d $$SDK_SRC/lib ]; then \
			echo "  Copying SDK libraries to bundled lib directory..."; \
			cp -L $$SDK_SRC/lib/*.so* $(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR)/ 2>/dev/null || true; \
		fi; \
		if [ -d $$SDK_SRC/lib/cvedix ]; then \
			cp -L $$SDK_SRC/lib/cvedix/*.so* $(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR)/ 2>/dev/null || true; \
		fi; \
	else \
		echo "  ⚠  Warning: /opt/edgeos-sdk not found in SDK extract or extract dir missing"; \
		echo "  SDK will not be bundled in this package"; \
	fi

	# Install default data from cvedix_data (fonts and models only)
	# These will be installed to /opt/omniapi/fonts and /opt/omniapi/models
	# as default data for users on fresh installations
	# NOTE: test_images and test_video are NOT copied to keep package size small
	@echo "Installing default data from cvedix_data..."; \
	if [ -d $(CURDIR)/cvedix_data ]; then \
		# Install default fonts \
		if [ -d $(CURDIR)/cvedix_data/font ]; then \
			echo "Installing default fonts..."; \
			install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/fonts; \
			cp -r $(CURDIR)/cvedix_data/font/* $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/fonts/ 2>/dev/null || true; \
			echo "  ✓ Default fonts installed"; \
		fi; \
		# Install default models \
		if [ -d $(CURDIR)/cvedix_data/models ]; then \
			echo "Installing default models..."; \
			install -d $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/models; \
			cp -r $(CURDIR)/cvedix_data/models/* $(CURDIR)/debian/$(PACKAGE_NAME)$(INSTALL_DIR)/models/ 2>/dev/null || true; \
			echo "  ✓ Default models installed"; \
		fi; \
		# Explicitly skip test_images and test_video to keep package size small \
		if [ -d $(CURDIR)/cvedix_data/test_images ] || [ -d $(CURDIR)/cvedix_data/test_video ]; then \
			echo "  Note: Skipping test_images and test_video (not included in package)"; \
		fi; \
	else \
		echo "  Note: cvedix_data directory not found, skipping default data installation"; \
	fi

	# Bundle GStreamer plugins (ALL-IN-ONE package includes bundled plugins)
	# bundle_libs.sh creates gstreamer-1.0 directory in LIB_DIR during bundling
	# We need to ensure it's properly installed to the package
	@GST_PLUGIN_DIR=$(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR)/gstreamer-1.0; \
	BUNDLED_GST_PLUGINS=$(CURDIR)/debian/$(PACKAGE_NAME)$(LIB_DIR)/gstreamer-1.0; \
	if [ -d "$$BUNDLED_GST_PLUGINS" ] && [ "$$(ls -A $$BUNDLED_GST_PLUGINS 2>/dev/null)" ]; then \
		echo "  ✓ Bundled GStreamer plugins found in $$BUNDLED_GST_PLUGINS"; \
		echo "  Plugin count: $$(ls -1 $$BUNDLED_GST_PLUGINS/*.so 2>/dev/null | wc -l)"; \
	else \
		echo "  ⚠  Bundled GStreamer plugins not found, copying from system..."; \
		install -d $$GST_PLUGIN_DIR; \
		# Copy essential plugins from common locations as fallback \
		for plugin_dir in /usr/lib/x86_64-linux-gnu/gstreamer-1.0 /usr/lib/gstreamer-1.0; do \
			if [ -d $$plugin_dir ]; then \
				echo "  Copying plugins from $$plugin_dir..."; \
				for plugin in libgstcoreelements.so libgstvideoconvert.so libgstapp.so libgstisomp4.so libgsth264parse.so libgstflvmux.so libgstrtmp.so libgstx264.so libgstlibav.so libgstplayback.so libgstvideo.so libgstaudio.so libgstfilesrc.so libgstappsink.so libgstappsrc.so; do \
					if [ -f $$plugin_dir/$$plugin ]; then \
						cp -L $$plugin_dir/$$plugin $$GST_PLUGIN_DIR/ 2>/dev/null || true; \
					fi; \
				done; \
				# Copy all plugins if essential ones were found \
				if [ -f $$GST_PLUGIN_DIR/libgstcoreelements.so ]; then \
					echo "  ✓ Essential plugins copied, copying remaining plugins..."; \
					cp -L $$plugin_dir/*.so $$GST_PLUGIN_DIR/ 2>/dev/null || true; \
				fi; \
				break; \
			fi; \
		done; \
		if [ ! -f $$GST_PLUGIN_DIR/libgstcoreelements.so ]; then \
			echo "  ⚠  Warning: Could not find GStreamer plugins to bundle"; \
			echo "  Service may fail if GStreamer plugins are not available on target system"; \
		fi; \
	fi

override_dh_shlibdeps:
	# Skip automatic shlibdeps - we bundle libraries ourselves
	:

override_dh_usrlocal:
	# Skip dh_usrlocal - we handle /usr/local/bin installation ourselves
	:

override_dh_strip:
	# Strip binaries. If objcopy OOM: run with DEB_BUILD_OPTIONS=noautodbgsym dpkg-buildpackage -b
	dh_strip

.PHONY: override_dh_auto_configure override_dh_auto_build override_dh_auto_install override_dh_shlibdeps override_dh_usrlocal override_dh_strip
